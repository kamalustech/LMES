Data Types
Strings
name = 'Dhoni'
name = "Dhoni"
name = '''Dhoni'''
name  = ("Dhoni",)

List
var = ["Kamal"]
var = [1,2,3,4,5]
var = [1, "Kamal", 12.3, True,["Sherlin",38]]

Tuples
var = ("Kamal",)
